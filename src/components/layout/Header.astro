---
import { getLangFromUrl, t, languages, getLocalizedPath, type Lang } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
const home = getLocalizedPath('/', lang);
const isHome = currentPath === '/';

const navItems = [
  { label: t(lang, 'nav.features'), href: `${isHome ? '' : home}#features` },
  { label: t(lang, 'nav.demo'), href: `${isHome ? '' : home}#demo` },
  { label: t(lang, 'nav.howItWorks'), href: `${isHome ? '' : home}#how-it-works` },
  { label: t(lang, 'nav.blog'), href: getLocalizedPath('/blog', lang) },
  { label: t(lang, 'nav.contact'), href: `${isHome ? '' : home}#contact` },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-base/80 backdrop-blur-md border-b border-border">
  <div class="max-w-(--container-max) mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 font-bold text-xl text-primary">
        <span class="bg-gradient-to-r from-cta to-accent bg-clip-text text-transparent">VRArena</span>
        <span>Loyalty</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-text-muted hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Language Switcher + CTA -->
      <div class="flex items-center gap-4">
        <div class="relative group">
          <button class="text-sm font-medium text-text-muted hover:text-primary uppercase">
            {lang}
          </button>
          <div class="absolute right-0 top-full mt-2 bg-bg-surface rounded-lg shadow-lg border border-border py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all min-w-[120px]">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={`/${code}${currentPath === '/' ? '' : currentPath}`}
                class:list={[
                  'block px-4 py-2 text-sm hover:bg-bg-muted transition-colors',
                  code === lang ? 'text-cta font-medium' : 'text-text-muted',
                ]}
              >
                {name}
              </a>
            ))}
          </div>
        </div>

        <a
          href={`${isHome ? '' : home}#contact`}
          class="hidden sm:inline-flex btn-pill bg-cta text-white hover:bg-cta-hover px-5 py-2 text-sm"
        >
          {t(lang, 'hero.cta')}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text-muted hover:text-primary"
          aria-label="Menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-border bg-bg-base">
    <nav class="px-4 py-4 space-y-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block text-base font-medium text-text-muted hover:text-primary"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<div class="h-16 sm:h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Close mobile menu on anchor click
  menu?.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
