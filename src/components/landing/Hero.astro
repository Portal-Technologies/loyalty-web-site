---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { getLangFromUrl, t } from '../../i18n';
import heroImage from '../../assets/screenshots/hero-image.jpg';

const lang = getLangFromUrl(Astro.url);
---

<section class="relative overflow-hidden bg-bg-dark text-text-light">
  <!-- Background image -->
  <Image
    src={heroImage}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    widths={[960, 1440, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <!-- Overlay -->
  <div class="absolute inset-0 bg-bg-dark/70"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(155,81,224,0.25),transparent_50%)]"></div>

  <div class="relative max-w-(--container-max) mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40 flex justify-end">
    <div class="max-w-2xl text-right">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight">
        {t(lang, 'hero.title')}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-white/80 leading-relaxed max-w-2xl">
        {t(lang, 'hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-wrap gap-4 justify-end">
        <Button href="#contact" variant="primary" size="lg">
          {t(lang, 'hero.cta')}
        </Button>
        <Button href="#features" variant="outline" size="lg" class="border-white/30 text-white hover:bg-white/10 hover:text-white">
          {t(lang, 'hero.ctaSecondary')}
        </Button>
      </div>
    </div>
  </div>

  <!-- Decorative circles (vr-arena style) -->
  <div class="absolute -bottom-20 -right-20 w-80 h-80 rounded-full bg-accent/20 blur-3xl"></div>
  <div class="absolute -top-10 -left-10 w-60 h-60 rounded-full bg-cta/20 blur-3xl"></div>
</section>
