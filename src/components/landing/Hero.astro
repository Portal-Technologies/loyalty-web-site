---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import { getLangFromUrl, t } from '../../i18n';
import heroImage from '../../assets/screenshots/hero-image.jpg';

const lang = getLangFromUrl(Astro.url);
---

<section class="relative overflow-hidden bg-bg-dark text-text-light">
  <!-- Background image -->
  <Image
    src={heroImage}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    widths={[960, 1440, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <!-- Overlay: strong on left, fades to transparent on right -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(10,10,10,0.95)_0%,rgba(10,10,10,0.85)_30%,rgba(10,10,10,0.4)_60%,rgba(10,10,10,0)_100%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(6,147,227,0.15),transparent_60%)]"></div>

  <div class="relative px-8 sm:px-12 lg:px-16 xl:px-24 py-24 sm:py-32 lg:py-40 flex justify-start">
    <div class="max-w-xl text-left">
      <p class="inline-block mb-5 px-3 py-1 rounded-full border border-white/20 bg-white/5 text-[11px] sm:text-xs font-semibold tracking-[0.18em] uppercase text-white/80 backdrop-blur-sm">
        {t(lang, 'hero.eyebrow')}
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight">
        {t(lang, 'hero.title')}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-white/80 leading-relaxed">
        {t(lang, 'hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-wrap gap-4 justify-start">
        <Button href="#contact" variant="primary" size="lg">
          {t(lang, 'hero.cta')}
        </Button>
        <Button href="#pains" variant="outline" size="lg" class="border-white/30 text-white hover:bg-white/10 hover:text-white">
          {t(lang, 'hero.ctaSecondary')}
        </Button>
      </div>
    </div>
  </div>

  <!-- Decorative circles (vr-arena style) -->
  <div class="absolute -bottom-20 -right-20 w-80 h-80 rounded-full bg-accent/20 blur-3xl"></div>
  <div class="absolute -top-10 -left-10 w-60 h-60 rounded-full bg-cta/20 blur-3xl"></div>
</section>
