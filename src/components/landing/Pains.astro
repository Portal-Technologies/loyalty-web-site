---
import Section from '../ui/Section.astro';
import { getLangFromUrl, t } from '../../i18n';

const lang = getLangFromUrl(Astro.url);

const pains = [
  {
    key: 'automation',
    accent: 'text-cta',
    badge: 'bg-cta/10 border-cta/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  },
  {
    key: 'tournaments',
    accent: 'text-accent',
    badge: 'bg-accent/10 border-accent/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3h14v2a5 5 0 01-5 5h-4a5 5 0 01-5-5V3z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v4m-4 7h8m-4-3v3M5 5H3a2 2 0 002 2h0m14-2h2a2 2 0 01-2 2h0" />`,
  },
  {
    key: 'staffMotivation',
    accent: 'text-cta',
    badge: 'bg-cta/10 border-cta/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z" />`,
  },
  {
    key: 'families',
    accent: 'text-accent',
    badge: 'bg-accent/10 border-accent/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
  {
    key: 'whatsapp',
    accent: 'text-cta',
    badge: 'bg-cta/10 border-cta/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
  },
  {
    key: 'localization',
    accent: 'text-accent',
    badge: 'bg-accent/10 border-accent/30',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
];
---

<Section id="pains">
  <div class="text-center mb-16">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary">
      {t(lang, 'pains.sectionTitle')}
    </h2>
    <p class="mt-4 text-lg text-text-muted max-w-3xl mx-auto">
      {t(lang, 'pains.sectionSubtitle')}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
    {pains.map((pain) => (
      <div class="bg-bg-surface rounded-2xl p-6 sm:p-8 border border-border hover:border-border-hover shadow-sm hover:shadow-md transition-all">
        <div class:list={['w-12 h-12 rounded-xl border flex items-center justify-center mb-5', pain.badge]}>
          <svg class:list={['w-6 h-6', pain.accent]} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={pain.icon} />
        </div>
        <h3 class="text-xl font-bold text-primary mb-3">
          {t(lang, `pains.${pain.key}.title`)}
        </h3>
        <p class="text-text-muted leading-relaxed">
          {t(lang, `pains.${pain.key}.description`)}
        </p>
      </div>
    ))}
  </div>
</Section>
