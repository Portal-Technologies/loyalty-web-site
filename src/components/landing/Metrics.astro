---
import Section from '../ui/Section.astro';
import { getLangFromUrl, t } from '../../i18n';

const lang = getLangFromUrl(Astro.url);

const metrics = [
  {
    value: t(lang, 'metrics.visits.value'),
    label: t(lang, 'metrics.visits.label'),
    description: t(lang, 'metrics.visits.description'),
    color: 'text-cta',
    iconColor: 'text-white',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />`,
  },
  {
    value: t(lang, 'metrics.revenue.value'),
    label: t(lang, 'metrics.revenue.label'),
    description: t(lang, 'metrics.revenue.description'),
    color: 'text-accent',
    iconColor: 'text-white',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />`,
  },
  {
    value: t(lang, 'metrics.share.value'),
    label: t(lang, 'metrics.share.label'),
    description: t(lang, 'metrics.share.description'),
    color: 'text-cta',
    iconColor: 'text-white',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />`,
  },
  {
    value: t(lang, 'metrics.growth.value'),
    label: t(lang, 'metrics.growth.label'),
    description: t(lang, 'metrics.growth.description'),
    color: 'text-accent',
    iconColor: 'text-white',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />`,
  },
];
---

<Section id="metrics">
  <div class="text-center mb-16">
    <h2 class="text-3xl sm:text-4xl font-bold text-primary">
      {t(lang, 'metrics.sectionTitle')}
    </h2>
    <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
      {t(lang, 'metrics.sectionSubtitle')}
    </p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
    {metrics.map((metric) => (
      <div class="text-center p-6 rounded-2xl bg-bg-surface border border-border hover:border-cta/30 transition-colors">
        <div class:list={['mx-auto mb-4 w-10 h-10', metric.iconColor]}>
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={metric.icon} />
        </div>
        <div class:list={['text-4xl sm:text-5xl font-extrabold mb-2', metric.color]}>
          {metric.value}
        </div>
        <div class="text-lg font-semibold text-primary mb-2">
          {metric.label}
        </div>
        <p class="text-sm text-text-muted leading-relaxed">
          {metric.description}
        </p>
      </div>
    ))}
  </div>
</Section>
