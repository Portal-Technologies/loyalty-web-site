---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/ui/Card.astro';
import { getCollection } from 'astro:content';
import { supportedLangs, getLangFromUrl, t, getLocalizedPath, type Lang } from '../../../i18n';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`${t(lang, 'blog.title')} — VRArena Loyalty`}>
  <section class="max-w-(--container-max) mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="text-center mb-16">
      <h1 class="text-3xl sm:text-4xl font-bold text-primary">
        {t(lang, 'blog.title')}
      </h1>
      <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
        {t(lang, 'blog.subtitle')}
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        {posts.map((post) => (
          <a href={getLocalizedPath(`/blog/${post.id.replace(`${lang}/`, '')}`, lang)}>
            <Card class="h-full hover:border-cta/30">
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-sm text-text-muted"
              >
                {post.data.pubDate.toLocaleDateString(lang, {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2 class="text-xl font-bold text-primary mt-2 mb-3">
                {post.data.title}
              </h2>
              <p class="text-text-muted text-sm leading-relaxed">
                {post.data.description}
              </p>
              <span class="inline-block mt-4 text-cta text-sm font-medium">
                {t(lang, 'blog.readMore')} →
              </span>
            </Card>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-center text-text-muted">No posts yet.</p>
    )}
  </section>
</BaseLayout>
