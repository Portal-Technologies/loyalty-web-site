---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supportedLangs, getLangFromUrl, t } from '../../i18n';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={`${t(lang, 'footer.privacy')} — VRArena Loyalty`}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">

    <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-3">
      Privacy Policy
    </h1>
    <p class="text-text-muted text-sm mb-12">Last updated: May 2025</p>

    <div class="space-y-10 text-text-muted leading-relaxed">

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Who We Are</h2>
        <p>
          Data controller is <strong class="text-primary font-medium">SPATIAL COMPUTING ENTERTAINMENT</strong>,
          registered at Dubai Silicon Oasis, DDP, Building A1, Dubai, United Arab Emirates.
        </p>
        <p class="mt-4">
          This Privacy Policy explains how we collect, use, and protect personal information
          when you visit <strong class="text-primary font-medium">loyalty.vr-arena.games</strong>
          (the "Site") or submit an inquiry through our contact form.
        </p>
        <p class="mt-4">
          If you have questions about this policy, contact us at
          <a href="mailto:ilia.e@vr-arena.games" class="text-cta hover:underline">ilia.e@vr-arena.games</a>.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Information Covered by This Policy</h2>
        <p>
          This policy covers all personal information collected and used in connection with
          this Site. Personal data includes information that enables you to be identified
          as an individual or recognised directly or indirectly — such as your name,
          email address, company name, and any other details you voluntarily provide.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">What Information Do We Collect?</h2>
        <p class="mb-4">
          This Site is a static marketing website. We do not require account creation
          and do not use advertising or analytics tracking cookies. The personal data we
          collect comes exclusively from voluntary actions:
        </p>
        <ul class="list-disc pl-6 space-y-2">
          <li>
            <strong class="text-primary font-medium">Contact form submissions</strong> — when you
            submit a demo request, we collect your name, email address, company or venue name,
            and the message you provide.
          </li>
          <li>
            <strong class="text-primary font-medium">Communications</strong> — information you provide
            when contacting us by email or other written correspondence, including your name,
            email address, and telephone number where given.
          </li>
          <li>
            <strong class="text-primary font-medium">Server access logs</strong> — our hosting
            infrastructure automatically records standard technical data (IP address, browser type,
            pages visited, timestamps) for security and operational purposes.
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">How Do We Use Your Personal Information?</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>To respond to your demo request or inquiry and follow up regarding VRArena Loyalty services;</li>
          <li>To comply with legal requirements and exercise or defend legal claims;</li>
          <li>To keep the Site safe and secure;</li>
          <li>To maintain accurate records of your contact preferences, including suppression lists for contacts who have requested no further communication.</li>
        </ul>
        <p class="mt-4">
          We do not sell, rent, or trade your personal data to third parties.
          We do not use your data for automated decision-making or profiling.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Legal Basis for Processing</h2>
        <p>
          We process your personal information on the basis of our legitimate interests —
          specifically in responding to business inquiries, exercising legal claims,
          preventing fraud or unlawful activity, and maintaining accurate contact preferences.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Where We Store Your Personal Information</h2>
        <p>
          Data is collected and stored in Dubai. It may be transferred to any company within
          the IFZA Group, regardless of geographic location. We also use the following
          third-party services to operate the Site:
        </p>
        <ul class="list-disc pl-6 space-y-3 mt-4">
          <li>
            <strong class="text-primary font-medium">Vercel</strong> — hosting and content delivery.
            Processes server logs in accordance with their
            <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-cta hover:underline">Privacy Policy</a>.
          </li>
          <li>
            <strong class="text-primary font-medium">Supabase</strong> — our contact form data is
            transmitted to a Supabase Edge Function for processing and delivery to our team.
            Processed in accordance with their
            <a href="https://supabase.com/privacy" target="_blank" rel="noopener noreferrer" class="text-cta hover:underline">Privacy Policy</a>.
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">How Do We Protect Your Information?</h2>
        <p>
          We implement appropriate technical and organisational measures to ensure the
          security, integrity, and accuracy of your personal data, and to protect it
          against unauthorised access, disclosure, alteration, or destruction.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Third-Party Websites</h2>
        <p>
          The Site may contain links to third-party websites or services. Those sites
          have their own privacy policies and we accept no responsibility or liability
          for their content or practices. We encourage you to review the privacy policy
          of any site you visit.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">How Long Do We Keep Your Information?</h2>
        <p>
          We retain personal data only for as long as necessary for the purposes described
          in this policy. Once data is no longer required, it is deleted or anonymised.
          You may request deletion of your data at any time by contacting us at
          <a href="mailto:ilia.e@vr-arena.games" class="text-cta hover:underline">ilia.e@vr-arena.games</a>.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Your Rights</h2>
        <p class="mb-4">
          Depending on your jurisdiction, you may have the following rights regarding your personal data:
        </p>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong class="text-primary font-medium">Access</strong> — request a copy of the data we hold about you;</li>
          <li><strong class="text-primary font-medium">Rectification</strong> — ask us to correct inaccurate or incomplete data;</li>
          <li><strong class="text-primary font-medium">Erasure</strong> — request deletion of your personal data;</li>
          <li><strong class="text-primary font-medium">Objection</strong> — object to how we process your data;</li>
          <li><strong class="text-primary font-medium">Portability</strong> — receive your data in a structured, machine-readable format.</li>
        </ul>
        <p class="mt-4">
          To exercise any of these rights, email us at
          <a href="mailto:ilia.e@vr-arena.games" class="text-cta hover:underline">ilia.e@vr-arena.games</a>.
          We will respond within 30 days.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Cookies</h2>
        <p>
          This Site does not use analytics or advertising cookies. Your browser may store
          a small number of technically necessary cookies set by our hosting infrastructure
          for security and performance. These cookies do not track you across other websites.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Changes to This Policy</h2>
        <p>
          We may update this Privacy Policy from time to time. Changes become effective
          upon posting to the Site with a revised date. Continued use of the Site after
          any changes constitutes your acceptance of the updated policy.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-4">Contact</h2>
        <p>
          For any privacy-related questions or requests:<br />
          <strong class="text-primary font-medium">SPATIAL COMPUTING ENTERTAINMENT</strong><br />
          Dubai Silicon Oasis, DDP, Building A1, Dubai, United Arab Emirates<br />
          <a href="mailto:ilia.e@vr-arena.games" class="text-cta hover:underline">ilia.e@vr-arena.games</a>
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
