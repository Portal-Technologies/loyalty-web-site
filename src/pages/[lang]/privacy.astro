---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supportedLangs, getLangFromUrl, t } from '../../i18n';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title={`${t(lang, 'footer.privacy')} — VRArena Loyalty`}>
  <section class="max-w-(--container-max) mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-8">
      {t(lang, 'footer.privacy')}
    </h1>
    <div class="prose prose-lg max-w-none">
      <p>Privacy policy content will be added here.</p>
    </div>
  </section>
</BaseLayout>
